# Frontend Environment Variables
# Copy this file to .env and update with your values

# API Configuration
# When running with Docker/Podman (recommended): Use relative path for nginx proxy
# VITE_API_URL=/api
# When running backend directly (development): Use full URL
# VITE_API_URL=http://localhost:3000/api
VITE_API_URL=/api
VITE_API_TIMEOUT=30000

# App Configuration
VITE_APP_NAME=Family Meal Planner
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_OFFLINE=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_ANALYTICS=false

# External Services (Optional)
VITE_GOOGLE_ANALYTICS_ID=
VITE_SENTRY_DSN=

# PWA Configuration
VITE_PWA_CACHE_NAME=meal-planner-cache-v1
VITE_PWA_CACHE_VERSION=1

# Development
VITE_ENABLE_DEV_TOOLS=true
VITE_LOG_LEVEL=debug