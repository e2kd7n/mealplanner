{
  "title": "Meal Planner",
  "uid": "mealplanner",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(mealplanner_http_requests_total[1m]))",
          "legendFormat": "requests/s"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "100 * sum(rate(mealplanner_http_requests_total{status_code=~\"5..\"}[1m])) / sum(rate(mealplanner_http_requests_total[1m]))",
          "legendFormat": "5xx error %"
        }
      ]
    },
    {
      "id": 3,
      "title": "Request Duration (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(mealplanner_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(mealplanner_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(mealplanner_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 4,
      "title": "Node.js Heap Used",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "targets": [
        {
          "expr": "mealplanner_nodejs_heap_size_used_bytes",
          "legendFormat": "heap used"
        },
        {
          "expr": "mealplanner_nodejs_heap_size_total_bytes",
          "legendFormat": "heap total"
        }
      ]
    },
    {
      "id": 5,
      "title": "DB Query Duration (p95)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(mealplanner_db_query_duration_seconds_bucket[5m])) by (le, result))",
          "legendFormat": "{{result}} p95"
        }
      ]
    },
    {
      "id": 6,
      "title": "Event Loop Lag (p99)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(mealplanner_nodejs_eventloop_lag_seconds_bucket[5m]))",
          "legendFormat": "event loop lag p99"
        }
      ]
    }
  ]
}
