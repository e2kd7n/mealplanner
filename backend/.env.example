# Backend Environment Variables
# IMPORTANT: Run ./scripts/generate-secrets.sh before first use to generate secure secrets
# Copy this file to .env and update with your values

# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database Configuration
# For Docker: Secrets are loaded from /run/secrets/ directory
# For local development: Set these manually or use the generated secrets
# DATABASE_URL will be constructed from secrets in production
DATABASE_URL=postgresql://mealplanner:REPLACE_WITH_POSTGRES_PASSWORD@localhost:5432/meal_planner

# Redis Configuration
# For Docker: Secrets are loaded from /run/secrets/ directory
# For local development: Set these manually or use the generated secrets
REDIS_URL=redis://:REPLACE_WITH_REDIS_PASSWORD@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD

# JWT Configuration
# For Docker: Secrets are loaded from /run/secrets/ directory
# For local development: Set these manually or use the generated secrets
# NEVER use placeholder values in production!
JWT_SECRET=REPLACE_WITH_JWT_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_JWT_REFRESH_SECRET
# Shorter token lifetimes for improved security (performance-first approach)
# Access token: 10 minutes (reduced from 15m for better security)
JWT_EXPIRES_IN=10m
# Refresh token: 1 day (reduced from 7d, cleared on browser close via sessionStorage)
JWT_REFRESH_EXPIRES_IN=1d

# CORS Configuration
CORS_ORIGIN=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# External APIs (Optional for MVP)
SPOONACULAR_API_KEY=
EDAMAM_APP_ID=
EDAMAM_APP_KEY=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
LOG_FORMAT=dev

# Password Policy Configuration
# Minimum password length (recommended: 8-16)
PASSWORD_MIN_LENGTH=8
# Maximum password length (recommended: 128)
PASSWORD_MAX_LENGTH=128
# Require at least one uppercase letter (A-Z)
PASSWORD_REQUIRE_UPPERCASE=true
# Require at least one lowercase letter (a-z)
PASSWORD_REQUIRE_LOWERCASE=true
# Require at least one number (0-9)
PASSWORD_REQUIRE_NUMBER=true
# Require at least one special character (!@#$%^&*()_+-=[]{}|;:,.<>?)
PASSWORD_REQUIRE_SPECIAL=true
# Minimum number of uppercase letters required
PASSWORD_MIN_UPPERCASE=1
# Minimum number of lowercase letters required
PASSWORD_MIN_LOWERCASE=1
# Minimum number of numbers required
PASSWORD_MIN_NUMBERS=1
# Minimum number of special characters required
PASSWORD_MIN_SPECIAL=1

# Session
# For Docker: Secrets are loaded from /run/secrets/ directory
# For local development: Set this manually or use the generated secrets
SESSION_SECRET=REPLACE_WITH_SESSION_SECRET