# Backend Environment Variables
#
# ⚠️  CRITICAL SECURITY NOTICE ⚠️
# 1. Run ./scripts/generate-secrets.sh BEFORE first use
# 2. NEVER commit .env files to version control
# 3. NEVER use placeholder values in production
# 4. Use different secrets for each environment
#
# Copy this file to .env and update with your values

# Server Configuration
NODE_ENV=development
PORT=3000
HTTPS_PORT=443
HOST=0.0.0.0

# HTTPS/SSL Configuration (optional)
USE_HTTPS=false
SSL_KEY_PATH=/app/certs/key.pem
SSL_CERT_PATH=/app/certs/cert.pem

# Database Configuration
# For Docker: Secrets are loaded from /run/secrets/ directory
# For local development: Generate secrets with ./scripts/generate-secrets.sh
# Then manually copy the generated password from secrets/postgres_password.txt
DATABASE_URL=postgresql://mealplanner:<POSTGRES_PASSWORD_FROM_SECRETS_FILE>@localhost:5432/meal_planner

# JWT Configuration
# For Docker: Secrets are loaded from /run/secrets/ directory
# For local development: Generate secrets with ./scripts/generate-secrets.sh
# Then manually copy the generated secrets from secrets/ directory
# CRITICAL: JWT secrets must be at least 32 characters and cryptographically random
JWT_SECRET=<JWT_SECRET_FROM_SECRETS_FILE>
JWT_REFRESH_SECRET=<JWT_REFRESH_SECRET_FROM_SECRETS_FILE>
# Shorter token lifetimes for improved security (performance-first approach)
# Access token: 10 minutes (reduced from 15m for better security)
JWT_EXPIRES_IN=10m
# Refresh token: 1 day (reduced from 7d, cleared on browser close via sessionStorage)
JWT_REFRESH_EXPIRES_IN=1d

# CORS Configuration
CORS_ORIGIN=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# External APIs (Optional for MVP)
SPOONACULAR_API_KEY=
EDAMAM_APP_ID=
EDAMAM_APP_KEY=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
LOG_FORMAT=dev

# Password Policy Configuration
# Minimum password length (recommended: 8-16)
PASSWORD_MIN_LENGTH=8
# Maximum password length (recommended: 128)
PASSWORD_MAX_LENGTH=128
# Require at least one uppercase letter (A-Z)
PASSWORD_REQUIRE_UPPERCASE=true
# Require at least one lowercase letter (a-z)
PASSWORD_REQUIRE_LOWERCASE=true
# Require at least one number (0-9)
PASSWORD_REQUIRE_NUMBER=true
# Require at least one special character (!@#$%^&*()_+-=[]{}|;:,.<>?)
PASSWORD_REQUIRE_SPECIAL=true
# Minimum number of uppercase letters required
PASSWORD_MIN_UPPERCASE=1
# Minimum number of lowercase letters required
PASSWORD_MIN_LOWERCASE=1
# Minimum number of numbers required
PASSWORD_MIN_NUMBERS=1
# Minimum number of special characters required
PASSWORD_MIN_SPECIAL=1

# Session
# For Docker: Secrets are loaded from /run/secrets/ directory
# For local development: Generate secrets with ./scripts/generate-secrets.sh
# Then manually copy the generated secret from secrets/session_secret.txt
SESSION_SECRET=<SESSION_SECRET_FROM_SECRETS_FILE>