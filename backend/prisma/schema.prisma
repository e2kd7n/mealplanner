generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String            @id @default(uuid())
  email           String            @unique
  passwordHash    String            @map("password_hash")
  familyName      String            @map("family_name")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  isBlocked       Boolean           @default(false) @map("is_blocked")
  role            UserRole          @default(user)
  familyMembers   FamilyMember[]
  groceryLists    GroceryList[]
  mealPlans       MealPlan[]
  pantryInventory PantryInventory[]
  recipeRatings   RecipeRating[]
  recipes         Recipe[]
  feedback        UserFeedback[]
  userPreferences UserPreferences?

  @@index([email])
  @@index([role])
  @@map("users")
}

model FamilyMember {
  id                  String         @id @default(uuid())
  userId              String         @map("user_id")
  name                String
  ageGroup            AgeGroup       @map("age_group")
  canCook             Boolean        @default(false) @map("can_cook")
  dietaryRestrictions Json           @map("dietary_restrictions")
  createdAt           DateTime       @default(now()) @map("created_at")
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  plannedMeals        PlannedMeal[]
  recipeRatings       RecipeRating[]

  @@map("family_members")
}

model Recipe {
  id            String             @id @default(uuid())
  userId        String?            @map("user_id")
  title         String
  description   String?
  source        RecipeSource
  externalId    String?            @map("external_id")
  prepTime      Int                @map("prep_time")
  cookTime      Int                @map("cook_time")
  servings      Int
  difficulty    Difficulty
  kidFriendly   Boolean            @default(false) @map("kid_friendly")
  cuisineType   String?            @map("cuisine_type")
  imageUrl      String?            @map("image_url")
  instructions  Json
  nutritionInfo Json?              @map("nutrition_info")
  costEstimate  Decimal?           @map("cost_estimate") @db.Decimal(10, 2)
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  sourceUrl     String?            @map("source_url")
  mealTypes     MealType[]         @map("meal_types")
  cleanupScore  Int?               @map("cleanup_score")
  plannedMeals  PlannedMeal[]
  ingredients   RecipeIngredient[]
  ratings       RecipeRating[]
  user          User?              @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([difficulty])
  @@index([cuisineType])
  @@index([kidFriendly])
  @@index([createdAt])
  @@index([title])
  @@index([sourceUrl])
  @@index([cuisineType(ops: raw("gin_trgm_ops"))], map: "recipes_cuisine_type_trgm_idx", type: Gin)
  @@index([description(ops: raw("gin_trgm_ops"))], map: "recipes_description_trgm_idx", type: Gin)
  @@index([title(ops: raw("gin_trgm_ops"))], map: "recipes_title_trgm_idx", type: Gin)
  @@map("recipes")
}

model Ingredient {
  id                String             @id @default(uuid())
  name              String             @unique
  category          IngredientCategory
  seasonalMonths    Int[]              @map("seasonal_months")
  averagePrice      Decimal            @map("average_price") @db.Decimal(10, 2)
  unit              String
  allergens         String[]
  createdAt         DateTime           @default(now()) @map("created_at")
  groceryListItems  GroceryListItem[]
  pantryInventory   PantryInventory[]
  recipeIngredients RecipeIngredient[]
  avoidedBy         UserPreferences[]  @relation("AvoidedIngredients")

  @@index([name(ops: raw("gin_trgm_ops"))], map: "ingredients_name_trgm_idx", type: Gin)
  @@map("ingredients")
}

model RecipeIngredient {
  id           String     @id @default(uuid())
  recipeId     String     @map("recipe_id")
  ingredientId String     @map("ingredient_id")
  quantity     Decimal    @db.Decimal(10, 2)
  unit         String
  notes        String?
  isOptional   Boolean    @default(false) @map("is_optional")
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@map("recipe_ingredients")
}

model MealPlan {
  id            String         @id @default(uuid())
  userId        String         @map("user_id")
  weekStartDate DateTime       @map("week_start_date") @db.Date
  status        MealPlanStatus
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  groceryLists  GroceryList[]
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  plannedMeals  PlannedMeal[]

  @@index([userId])
  @@index([weekStartDate])
  @@index([status])
  @@map("meal_plans")
}

model PlannedMeal {
  id             String        @id @default(uuid())
  mealPlanId     String        @map("meal_plan_id")
  recipeId       String        @map("recipe_id")
  date           DateTime      @db.Date
  mealType       MealType      @map("meal_type")
  servings       Int
  assignedCookId String?       @map("assigned_cook")
  notes          String?
  isLeftover     Boolean       @default(false) @map("is_leftover")
  assignedCook   FamilyMember? @relation(fields: [assignedCookId], references: [id])
  mealPlan       MealPlan      @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  recipe         Recipe        @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([mealPlanId])
  @@index([recipeId])
  @@index([date])
  @@map("planned_meals")
}

model GroceryList {
  id                 String            @id @default(uuid())
  mealPlanId         String            @map("meal_plan_id")
  userId             String            @map("user_id")
  status             GroceryListStatus
  totalEstimatedCost Decimal?          @map("total_estimated_cost") @db.Decimal(10, 2)
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  items              GroceryListItem[]
  mealPlan           MealPlan          @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([mealPlanId])
  @@index([status])
  @@map("grocery_lists")
}

model GroceryListItem {
  id             String      @id @default(uuid())
  groceryListId  String      @map("grocery_list_id")
  ingredientId   String      @map("ingredient_id")
  quantity       Decimal     @db.Decimal(10, 2)
  unit           String
  estimatedPrice Decimal     @map("estimated_price") @db.Decimal(10, 2)
  isChecked      Boolean     @default(false) @map("is_checked")
  storeSection   String?     @map("store_section")
  notes          String?
  groceryList    GroceryList @relation(fields: [groceryListId], references: [id], onDelete: Cascade)
  ingredient     Ingredient  @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@map("grocery_list_items")
}

model RecipeRating {
  id             String        @id @default(uuid())
  recipeId       String        @map("recipe_id")
  userId         String        @map("user_id")
  familyMemberId String?       @map("family_member_id")
  rating         Int
  notes          String?
  wouldMakeAgain Boolean       @map("would_make_again")
  createdAt      DateTime      @default(now()) @map("created_at")
  familyMember   FamilyMember? @relation(fields: [familyMemberId], references: [id])
  recipe         Recipe        @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([recipeId])
  @@index([userId])
  @@index([rating])
  @@map("recipe_ratings")
}

model UserPreferences {
  id                   String       @id @default(uuid())
  userId               String       @unique @map("user_id")
  weeklyBudget         Decimal?     @map("weekly_budget") @db.Decimal(10, 2)
  preferredCuisines    String[]     @map("preferred_cuisines")
  cookingSkillLevel    SkillLevel   @map("cooking_skill_level")
  maxPrepTimeWeeknight Int          @map("max_prep_time_weeknight")
  maxPrepTimeWeekend   Int          @map("max_prep_time_weekend")
  dietaryPreferences   Json         @map("dietary_preferences")
  notificationSettings Json         @map("notification_settings")
  user                 User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  avoidedIngredients   Ingredient[] @relation("AvoidedIngredients")

  @@map("user_preferences")
}

model PantryInventory {
  id             String         @id @default(uuid())
  userId         String         @map("user_id")
  ingredientId   String         @map("ingredient_id")
  quantity       Decimal        @db.Decimal(10, 2)
  unit           String
  expirationDate DateTime?      @map("expiration_date") @db.Date
  location       PantryLocation
  updatedAt      DateTime       @updatedAt @map("updated_at")
  ingredient     Ingredient     @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([ingredientId])
  @@index([expirationDate])
  @@map("pantry_inventory")
}

model ClientLog {
  id        String   @id @default(uuid())
  level     String
  message   String
  context   String?
  sessionId String   @map("session_id")
  userAgent String?  @map("user_agent")
  url       String?
  stack     String?
  data      Json?
  timestamp BigInt
  createdAt DateTime @default(now()) @map("created_at")

  @@index([level])
  @@index([sessionId])
  @@index([context])
  @@index([timestamp])
  @@index([createdAt])
  @@map("client_logs")
}

model UserFeedback {
  id           String         @id @default(uuid())
  userId       String         @map("user_id")
  page         String
  feedbackType FeedbackType   @map("feedback_type")
  rating       Int?
  message      String
  screenshot   String?
  status       FeedbackStatus @default(pending)
  adminNotes   String?        @map("admin_notes")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([feedbackType])
  @@index([status])
  @@index([createdAt])
  @@map("user_feedback")
}

enum UserRole {
  user
  admin
  superadmin
}

enum AgeGroup {
  child
  teen
  adult
}

enum RecipeSource {
  custom
  imported
  api
  spoonacular
}

enum Difficulty {
  easy
  medium
  hard
}

enum MealType {
  breakfast
  lunch
  dinner
  snack
  dessert
}

enum IngredientCategory {
  produce
  protein
  dairy
  grains
  pantry
  spices
  other
}

enum MealPlanStatus {
  draft
  active
  completed
}

enum GroceryListStatus {
  draft
  shopping
  completed
}

enum SkillLevel {
  beginner
  intermediate
  advanced
}

enum PantryLocation {
  fridge
  freezer
  pantry
}

enum FeedbackType {
  bug
  feature
  improvement
  question
  other
}

enum FeedbackStatus {
  pending
  reviewed
  in_progress
  resolved
  wont_fix
}
