{
  "name": "meal-planner-backend",
  "version": "1.0.0",
  "description": "Backend API for Family Meal Planner",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:safe": "cd .. && ./scripts/safe-migrate.sh",
    "prisma:migrate:prod": "cd .. && ./scripts/safe-migrate.sh --production",
    "prisma:backup": "cd .. && ./scripts/pre-migration-backup.sh",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:seed:visual-login": "ts-node prisma/seed-visual-login.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "meal-planner",
    "recipe",
    "grocery",
    "api"
  ],
  "author": "",
  "license": "PROPRIETARY",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "prisma"
    ],
    "overrides": {
      "flatted": ">=3.4.2",
      "path-to-regexp": "0.1.13",
      "picomatch": ">=4.0.4",
      "brace-expansion": ">=5.0.6",
      "cookie": ">=0.7.0"
    }
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@rethora/url-recipe-scraper": "^1.1.0",
    "axios": "^1.18.1",
    "bcrypt": "^6.0.0",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dompurify": "^3.4.1",
    "dotenv": "^16.4.7",
    "express": "^4.22.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "html-entities": "^2.6.0",
    "isomorphic-dompurify": "^2.36.0",
    "jsdom": "^25.0.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "node-cache": "^5.1.2",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.3",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/csurf": "^1.11.5",
    "@types/express": "^5.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.20.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "globals": "^17.6.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.4",
    "prisma": "^6.19.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
