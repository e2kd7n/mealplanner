{
  "name": "meal-planner-backend",
  "version": "1.0.0",
  "description": "Backend API for Family Meal Planner",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "meal-planner",
    "recipe",
    "grocery",
    "api"
  ],
  "author": "",
  "license": "PROPRIETARY",
  "pnpm": {
    "overrides": {
      "flatted": ">=3.4.2",
      "path-to-regexp": "0.1.13",
      "picomatch": ">=4.0.4",
      "brace-expansion": ">=5.0.5",
      "cookie": ">=0.7.0"
    }
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@rethora/url-recipe-scraper": "^1.1.0",
    "axios": "^1.15.2",
    "bcrypt": "^6.0.0",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dompurify": "^3.4.1",
    "dotenv": "^16.4.7",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "html-entities": "^2.6.0",
    "isomorphic-dompurify": "^2.36.0",
    "jsdom": "^25.0.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "node-cache": "^5.1.2",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/csurf": "^1.11.5",
    "@types/dompurify": "^3.2.0",
    "@types/express": "^5.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.13.5",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "prisma": "^6.19.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
