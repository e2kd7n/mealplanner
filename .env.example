# Root Environment Variables
#
# ⚠️  SECURITY WARNING ⚠️
# DO NOT use placeholder values in production!
# Run ./scripts/generate-secrets.sh to generate secure secrets
#
# Copy this file to .env and update with your values

# Database Configuration
# Generate secure password with: ./scripts/generate-secrets.sh
POSTGRES_PASSWORD=<GENERATE_WITH_SCRIPT>

# Database URLs
# Development: Use local database for development/testing
# Production: Use separate production database (NEVER use dev DB in production!)
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@localhost:5432/mealplanner_dev
# For production, use a different database name:
# DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@localhost:5432/mealplanner_prod

# JWT Secrets
# Generate secure secrets with: ./scripts/generate-secrets.sh
# NEVER use predictable or short values for JWT secrets!
JWT_SECRET=<GENERATE_WITH_SCRIPT>
JWT_REFRESH_SECRET=<GENERATE_WITH_SCRIPT>

# External APIs (optional for MVP)
# Obtain from respective service providers
SPOONACULAR_API_KEY=<YOUR_API_KEY_HERE>
EDAMAM_APP_ID=<YOUR_APP_ID_HERE>
EDAMAM_APP_KEY=<YOUR_APP_KEY_HERE>

# Environment
NODE_ENV=development